---
const links = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/jongwon-choi-366b5b111/' },
  { label: 'GitHub', href: 'https://github.com/jongwony' },
  { label: 'Email', href: 'mailto:lastone9182@gmail.com' },
  { label: 'Instagram', href: 'https://instagram.com/jongwony_' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <title>Jongwon Choi</title>
    <meta
      name="description"
      content="최종원 — 딜라이트룸(Alarmy) 데이터 엔지니어. 발표·대외 활동 이력과 사이드 프로젝트를 소개합니다."
    />
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.6/dist/web/static/pretendard.css"
    />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4530873656649886"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <main>
      <h1>Jongwon Choi</h1>
      <p class="role">
        Data Engineer at
        <a href="https://delightroom.com/">딜라이트룸 (Alarmy)</a>
      </p>
      <p class="note">사이트를 새로 만드는 중입니다. 그동안은 아래에서 만나요.</p>
      <ul class="links">
        {
          links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --font-sans:
      'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui, Roboto,
      'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo', 'Noto Sans KR', 'Malgun Gothic',
      'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', sans-serif;

    --surface-bg: #ffffff;
    --color-text: #1b1f27;
    --color-text-muted: #737680;
    --color-border: #e4e8ee;

    --color-accent-subtle: #e3eeff;
    --color-accent-strong: #0f5fe3;

    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;
    --space-7: 48px;

    --radius-pill: 999px;
    --duration-hover: 150ms;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: var(--space-5);
    background: var(--surface-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  main {
    text-align: center;
    max-width: 32rem;
  }

  h1 {
    margin: 0;
    font: 700 clamp(2rem, 8vw, 3.5rem) / 1.25 var(--font-sans);
    letter-spacing: -0.02em;
  }

  .role {
    margin: var(--space-3) 0 0;
    font: 400 1rem/1.75 var(--font-sans);
  }

  .role a {
    color: var(--color-accent-strong);
    text-decoration: none;
  }

  .role a:hover {
    text-decoration: underline;
  }

  .note {
    margin: var(--space-4) 0 0;
    font: 400 0.9375rem/1.75 var(--font-sans);
    color: var(--color-text-muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin: var(--space-7) 0 0;
    padding: 0;
    list-style: none;
  }

  .links a {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-text);
    font: 500 0.9375rem/1.5 var(--font-sans);
    text-decoration: none;
    transition: border-color var(--duration-hover) ease-out,
      background-color var(--duration-hover) ease-out;
  }

  .links a:hover {
    border-color: var(--color-accent-strong);
    background: var(--color-accent-subtle);
    color: var(--color-accent-strong);
  }
</style>
